# OpenAI-compatible local LLM (Lemonade, Ollama, etc.)
# Lemonade: http://localhost:<port>/api/v1  (see `lemonade status` for your port)
# Ollama:   http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:13305/api/v1
OPENAI_API_KEY=lemonade
OPENAI_MODEL=default

# When running the app in Docker and the LLM server is on the host:
# OPENAI_BASE_URL=http://host.docker.internal:13305/api/v1
